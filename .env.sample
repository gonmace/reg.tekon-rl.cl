DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=reg.tekon-rl.cl
DJANGO_SECRET_KEY=<generate-a-strong-secret-key>

POSTGRES_DB=reportestekon
POSTGRES_USER=<db-user>
POSTGRES_PASSWORD=<strong-password>
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/1

EMAIL_HOST=<smtp-server>
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=<email@example.com>
EMAIL_HOST_PASSWORD=<email-password>
DEFAULT_FROM_EMAIL=<noreply@example.com>

CSRF_TRUSTED_ORIGINS=https://reg.tekon-rl.cl

SITE_URL=https://reg.tekon-rl.cl

GUNICORN_WORKERS=3
DJANGO_LOG_FILE=/app/logs/django.log

# Superusuario inicial (solo se usa si no existe ningún superusuario)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=<strong-password>
